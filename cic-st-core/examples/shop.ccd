# Cicada3301
# ═══════════════════════════════════════════════════════════
# 🛍️ Shop Bot - Магазин с корзиной и каталогом
# ═══════════════════════════════════════════════════════════

версия "1.0"
бот "1768487637:AAGvL7s0ysWyJuVG5vplY5yJu_HsTLSeHSE"

команды:
    "/start" - "🚀 Запуск"
    "/catalog" - "📦 Каталог"
    "/cart" - "🛒 Корзина"
    "/order" - "📋 Заказ"
    "/support" - "💬 Поддержка"

глобально магазин_открыт = истина
глобально валюта = "₽"
глобально доставка = 300

# ──────────────────────────────────────────────────────────
блок приветствие:
    ответ "👋 Привет, {пользователь.имя}! Добро пожаловать в наш магазин 🛍️"

блок главное_меню:
    ответ "Выберите раздел:"
    кнопки:
        ["📦 Каталог", "🛒 Корзина"]
        ["📋 Мой заказ", "💬 Поддержка"]

# ──────────────────────────────────────────────────────────
старт:
    использовать приветствие
    использовать главное_меню
    получить "первый_визит" → первый
    если первый != ложь:
        ответ "🎁 Первый визит! Дарим скидку 10%!"
        сохранить "скидка" = 10
        сохранить "первый_визит" = ложь

команда "/catalog":
    если не магазин_открыт:
        ответ "🚫 Магазин закрыт на обслуживание"
        вернуть
    запустить каталог

команда "/cart":
    запустить корзина

команда "/order":
    получить "корзина" → товары
    если тип(товары) != "список" или длина(товары) == 0:
        ответ "🛒 Корзина пуста! Добавьте товары из каталога"
    иначе:
        запустить оформление

команда "/support":
    запустить поддержка

# ──────────────────────────────────────────────────────────
# Кнопки главного меню — заменяем "команда" на запустить/вернуть
при нажатии "📦 Каталог":
    если не магазин_открыт:
        ответ "🚫 Магазин закрыт на обслуживание"
        вернуть
    запустить каталог

при нажатии "🛒 Корзина":
    запустить корзина

при нажатии "📋 Мой заказ":
    получить "корзина" → товары
    если тип(товары) != "список":
        запомни товары = []
    если длина(товары) == 0:
        ответ "🛒 Корзина пуста! Добавьте товары из каталога"
        использовать главное_меню
    иначе:
        запустить оформление

при нажатии "💬 Поддержка":
    запустить поддержка

# ──────────────────────────────────────────────────────────
# Сценарий каталога
сценарий каталог:
    шаг выбор:
        ответ "📦 Наши товары:"
        ответ "1. 🍎 Яблоки - 100{валюта}"
        ответ "2. 🍌 Бананы - 80{валюта}"
        ответ "3. 🍊 Апельсины - 120{валюта}"
        ответ "4. 🍇 Виноград - 200{валюта}"
        кнопка "Добавить Яблоки" -> "add_apple"
        кнопка "Добавить Бананы" -> "add_banana"
        кнопка "Добавить Апельсины" -> "add_orange"
        кнопка "Добавить Виноград" -> "add_grape"
        кнопка "🔙 Готово" -> "done"
        завершить сценарий

# Добавление в корзину
при нажатии "add_apple":
    получить "корзина" → корзина
    если тип(корзина) != "список":
        запомни корзина = []
    запомни корзина = добавить(корзина, "Яблоки")
    сохранить "корзина" = корзина
    ответ "✅ Яблоки добавлены!"

при нажатии "add_banana":
    получить "корзина" → корзина
    если тип(корзина) != "список":
        запомни корзина = []
    запомни корзина = добавить(корзина, "Бананы")
    сохранить "корзина" = корзина
    ответ "✅ Бананы добавлены!"

при нажатии "add_orange":
    получить "корзина" → корзина
    если тип(корзина) != "список":
        запомни корзина = []
    запомни корзина = добавить(корзина, "Апельсины")
    сохранить "корзина" = корзина
    ответ "✅ Апельсины добавлены!"

при нажатии "add_grape":
    получить "корзина" → корзина
    если тип(корзина) != "список":
        запомни корзина = []
    запомни корзина = добавить(корзина, "Виноград")
    сохранить "корзина" = корзина
    ответ "✅ Виноград добавлен!"

при нажатии "done":
    ответ "👍 Готово! Перейдите в корзину для оформления"
    использовать главное_меню

# ──────────────────────────────────────────────────────────
# Сценарий корзины
сценарий корзина:
    шаг просмотр:
        получить "корзина" → товары
        если тип(товары) != "список" или длина(товары) == 0:
            ответ "🛒 Корзина пуста"
            использовать главное_меню
            завершить сценарий
        ответ "🛒 Ваша корзина:"
        ответ "Товаров: {длина(товары)} шт."
        ответ "💰 Примерная сумма: {длина(товары) * 100}{валюта}"
        кнопки:
            ["🗑️ Очистить", "📋 Оформить"]
            ["🔙 Назад"]
        завершить сценарий

при нажатии "🗑️ Очистить":
    сохранить "корзина" = []
    ответ "🗑️ Корзина очищена"
    использовать главное_меню

при нажатии "📋 Оформить":
    получить "корзина" → товары
    если тип(товары) != "список" или длина(товары) == 0:
        ответ "🛒 Корзина пуста! Добавьте товары из каталога"
    иначе:
        запустить оформление

при нажатии "🔙 Назад":
    использовать главное_меню

# ──────────────────────────────────────────────────────────
# Сценарий оформления заказа — правильный паттерн: спросить отдельным шагом
сценарий оформление:
    шаг адрес:
        запомни адрес = ""
        спросить "📍 Введите адрес доставки:" → адрес

    шаг проверка_адреса:
        если длина(адрес) < 10:
            ответ "❗ Адрес слишком короткий (минимум 10 символов)"
            повторить шаг
        сохранить "адрес" = адрес

    шаг телефон:
        запомни телефон = ""
        спросить "📞 Введите телефон:" → телефон

    шаг проверка_телефона:
        если длина(телефон) < 10:
            ответ "❗ Некорректный телефон (минимум 10 цифр)"
            повторить шаг
        сохранить "телефон" = телефон

    шаг подтверждение:
        получить "адрес" → адрес_доставки
        получить "корзина" → товары_заказа
        ответ "📋 Подтвердите заказ:"
        ответ "Товаров: {длина(товары_заказа)}"
        ответ "Адрес: {адрес_доставки}"
        ответ "Доставка: {доставка}{валюта}"
        кнопки:
            ["✅ Подтвердить", "❌ Отменить"]
        завершить сценарий

при нажатии "✅ Подтвердить":
    ответ "✅ Заказ принят!"
    ответ "Скоро свяжемся для подтверждения"
    сохранить "корзина" = []
    использовать главное_меню

при нажатии "❌ Отменить":
    ответ "❌ Заказ отменён"
    использовать главное_меню

# ──────────────────────────────────────────────────────────
# Сценарий поддержки — тоже правильный паттерн
сценарий поддержка:
    шаг вопрос:
        запомни вопрос = ""
        ответ "💬 Служба поддержки"
        спросить "Опишите ваш вопрос:" → вопрос

    шаг проверка_вопроса:
        если длина(вопрос) < 5:
            ответ "❗ Описание слишком короткое (минимум 5 символов)"
            повторить шаг
        лог "Тикет от {пользователь.имя}: {вопрос}"
        ответ "📨 Ваш вопрос принят!"
        ответ "Ответим в течение 24 часов"
        использовать главное_меню
        завершить сценарий

# ──────────────────────────────────────────────────────────
иначе:
    ответ "🤔 Не понимаю '{текст}'"
    ответ "Используйте кнопки меню или /help"
