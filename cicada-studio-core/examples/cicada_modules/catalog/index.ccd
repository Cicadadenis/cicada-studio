# Cicada3301
# Модуль каталога из БД.
# Подключение из бота: импорт "cicada.catalog"
#
# Ключи БД:
#   "категории"              → список строк категорий
#   "товары_{категория}"     → список строк товаров выбранной категории
#   "текущая_категория"      → последняя выбранная категория

блок каталог_меню:
    ответ "Каталог"
    inline-кнопки:
        ["📂 Категории" → "catalog:categories", "➕ Категория" → "catalog:add_category"]

блок каталог_категории:
    получить "категории" → категории
    если тип(категории) != "список":
        запомни категории = []

    если длина(категории) == 0:
        ответ "Категорий пока нет."
        inline-кнопки:
            ["➕ Создать категорию" → "catalog:add_category"]
    иначе:
        ответ "Выберите категорию:"
        inline из бд "категории" callback "catalog:cat:" columns=2 назад "⬅️ Назад" → "catalog:menu"
        ответ "Управление:"
        inline-кнопки:
            ["➕ Создать категорию" → "catalog:add_category"]

блок каталог_товары:
    ответ "Категория: {selected_category}"
    получить "товары_{selected_category}" → товары
    если тип(товары) != "список":
        запомни товары = []

    если длина(товары) == 0:
        ответ "В этой категории пока нет товаров."
    иначе:
        ответ "Товары:"
        inline из бд "товары_{selected_category}" callback "catalog:product:" columns=2 назад "⬅️ К категориям" → "catalog:categories"

    ответ "Действия:"
    inline-кнопки:
        ["➕ Создать товар" → "catalog:add_product", "⬅️ К категориям" → "catalog:categories"]

при нажатии "catalog:menu":
    использовать каталог_меню

при нажатии "catalog:categories":
    использовать каталог_категории

при нажатии "catalog:add_category":
    запустить каталог_создание_категории

при нажатии "catalog:add_product":
    получить "текущая_категория" → selected_category
    если не selected_category:
        ответ "Сначала выберите категорию."
        использовать каталог_категории
        вернуть
    запустить каталог_создание_товара

при нажатии:
    если начинается_с(кнопка, "catalog:cat:"):
        запомни selected_category = срез(кнопка, 12)
        сохранить "текущая_категория" = selected_category
        использовать каталог_товары
        вернуть

    если начинается_с(кнопка, "catalog:product:"):
        запомни selected_product = срез(кнопка, 16)
        ответ "Вы выбрали товар: {selected_product}"
        вернуть

сценарий каталог_создание_категории:
    шаг имя:
        спросить "Введите название категории:" → category_name

    шаг сохранить:
        получить "категории" → категории
        если тип(категории) != "список":
            запомни категории = []

        если содержит_элемент(категории, category_name):
            ответ "Такая категория уже есть: {category_name}"
        иначе:
            запомни категории = добавить(категории, category_name)
            сохранить "категории" = категории
            ответ "Категория создана: {category_name}"

        использовать каталог_категории
        завершить сценарий

сценарий каталог_создание_товара:
    шаг имя:
        спросить "Введите название товара для категории {selected_category}:" → product_name

    шаг сохранить:
        получить "товары_{selected_category}" → товары
        если тип(товары) != "список":
            запомни товары = []

        если содержит_элемент(товары, product_name):
            ответ "Такой товар уже есть: {product_name}"
        иначе:
            запомни товары = добавить(товары, product_name)
            сохранить "товары_{selected_category}" = товары
            ответ "Товар создан: {product_name}"

        использовать каталог_товары
        завершить сценарий
