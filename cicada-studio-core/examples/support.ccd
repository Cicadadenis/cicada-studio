# Cicada3301
# ═══════════════════════════════════════════════════════════
# 💬 Support Bot - Система поддержки с тикетами
# Пример middleware, логирования и работы с FSM
# ═══════════════════════════════════════════════════════════

версия "1.0"
#бот "ВАШ_TOKEN"
бот "1768487637:AAHIEAeYSdN3OA1EkNqQiUuBJLDEnfAHch0"
# ──────────────────────────────────────────────────────────
команды:
    "/start" - "🚀 Запуск"
    "/new_ticket" - "🎫 Новый тикет"
    "/my_tickets" - "📋 Мои тикеты"
    "/faq" - "❓ FAQ"
    "/operator" - "👨‍💼 Связь с оператором"

# Глобальные настройки
глобально support_open = истина
глобально operators = ["admin1", "admin2"]
глобально max_tickets_per_user = 5

# ──────────────────────────────────────────────────────────
# Middleware - выполняется для каждого сообщения

до каждого:
    # Логируем все обращения
    лог "{пользователь.имя} ({пользователь.id}): {текст}"
    
    # Считаем активность
    получить "total_messages" → msgs
    если тип(msgs) != "число":
        запомни msgs = 0
    сохранить "total_messages" = msgs + 1
    
    # Проверяем, не заблокирован ли пользователь
    получить "blocked" → blocked
    если blocked == истина:
        ответ "🚫 Ваш аккаунт заблокирован в поддержке"
        вернуть

после каждого:
    # Проверяем активность для бонусов
    получить "total_messages" → total
    если total == 50:
        ответ "🌟 Вы активный пользователь поддержки!"
        кнопка "Получить бонус" -> "loyalty_bonus"

# ──────────────────────────────────────────────────────────
старт:
    ответ "👋 Добро пожаловать в службу поддержки!"
    ответ "Здесь вы можете:"
    ответ "• Создать тикет"
    ответ "• Посмотреть FAQ"
    ответ "• Связаться с оператором"
    
    кнопка "🎫 Новый тикет" -> "new_ticket"
    кнопка "📋 Мои тикеты" -> "my_tickets"
    кнопка "❓ FAQ" -> "faq"
    кнопка "👨‍💼 Оператор" -> "operator"

команда "/new_ticket":
    если не support_open:
        ответ "🚫 Поддержка временно недоступна"
        вернуть
    
    # Проверяем лимит тикетов
    получить "ticket_count" → count
    если тип(count) != "число":
        запомни count = 0
    
    если count >= max_tickets_per_user:
        ответ "⚠️ Достигнут лимит активных тикетов ({max_tickets_per_user})"
        ответ "Дождитесь ответа на существующие"
        вернуть
    
    запустить создание_тикета

команда "/my_tickets":
    получить "ticket_count" → count
    если тип(count) != "число":
        запомни count = 0
    получить "tickets" → tickets
    если тип(tickets) != "массив" или длина(tickets) == 0:
        ответ "📭 У вас нет активных тикетов"
        кнопка "Создать тикет" -> "new_ticket_btn"
    иначе:
        ответ "📋 Ваши тикеты ({длина(tickets)}):"
        ответ "Последний: #{длина(tickets)}"
        кнопка "Проверить статус" -> "check_status"
        кнопка "Закрыть тикет" -> "close_ticket"
        кнопка "Новый тикет" -> "new_ticket_btn"

команда "/faq":
    запустить faq

команда "/operator":
    запустить чат_с_оператором

# ──────────────────────────────────────────────────────────
при нажатии "new_ticket":
    если не support_open:
        ответ "🚫 Поддержка временно недоступна"
        вернуть
    
    # Проверяем лимит тикетов
    получить "ticket_count" → count
    если тип(count) != "число":
        запомни count = 0
    
    если count >= max_tickets_per_user:
        ответ "⚠️ Достигнут лимит активных тикетов ({max_tickets_per_user})"
        ответ "Дождитесь ответа на существующие"
        вернуть
    
    запустить создание_тикета

при нажатии "my_tickets":
    получить "ticket_count" → count
    если тип(count) != "число":
        запомни count = 0
    получить "tickets" → tickets
    если тип(tickets) != "массив" или длина(tickets) == 0:
        ответ "📭 У вас нет активных тикетов"
        кнопка "Создать тикет" -> "new_ticket_btn"
    иначе:
        ответ "📋 Ваши тикеты ({длина(tickets)}):"
        ответ "Последний: #{длина(tickets)}"
        кнопка "Проверить статус" -> "check_status"
        кнопка "Закрыть тикет" -> "close_ticket"
        кнопка "Новый тикет" -> "new_ticket_btn"

при нажатии "faq":
    запустить faq

при нажатии "operator":
    запустить чат_с_оператором

# Обработчики категорий (не используются - сценарий только с текстовым вводом)
# при нажатии "cat_tech":
#     сохранить "ticket_category" = "Технический вопрос"
#     ответ "✅ Категория: Технический вопрос"
#     запустить создание_тикета

# Обработчики приоритетов (не используются - сценарий только с текстовым вводом)
# при нажатии "prio_critical":
#     сохранить "ticket_priority" = "Критичный"
#     ответ "✅ Приоритет: Критичный"
#     запустить создание_тикета

# Обработчики FAQ
при нажатии "more_faq":
    запустить faq

при нажатии "main_menu":
    старт

# Обработчики тикетов
при нажатии "check_status":
    ответ "📋 Статус тикета: в обработке"

при нажатии "close_ticket":
    ответ "✅ Тикет закрыт"

при нажатии "loyalty_bonus":
    ответ "🎁 Бонус начислен! +50 монет"
    получить "баланс" → текущий
    если тип(текущий) != "число":
        запомни текущий = 0
    сохранить "баланс" = текущий + 50

# ──────────────────────────────────────────────────────────
# Сценарий создания тикета
сценарий создание_тикета:
    шаг категория:
        запомни категория = ""
        ответ "🎫 Создание нового тикета"
        ответ "Выберите категория:"
        ответ "• 🔧 Технический вопрос"
        ответ "• 💰 Оплата"
        ответ "• 🐛 Баг"
        ответ "• ❓ Другое"
        спросить "Введите категория:" → категория
        если не категория:
            ответ "❗ Категория обязательна"
            повторить шаг
        сохранить "ticket_category" = категория
    
    шаг приоритет:
        запомни приоритет = ""
        ответ "Выберите приоритет:"
        ответ "• 🔴 Критичный"
        ответ "• 🟡 Высокий"
        ответ "• 🟢 Обычный"
        ответ "• 🔵 Низкий"
        спросить "Введите приоритет:" → приоритет
        если не приоритет:
            запомни приоритет = "Обычный"
        сохранить "ticket_priority" = приоритет
    
    шаг описание:
        спросить "📝 Опишите проблему подробно:" → описание
        если длина(описание) < 20:
            ответ "❗ Описание должно быть минимум 20 символов"
            повторить шаг
        
        # Проверяем, не дубликат ли
        получить "last_ticket_text" → last
        если last == описание:
            ответ "⚠️ Это дубликат предыдущего тикета"
            вернуть
        
        сохранить "last_ticket_text" = описание
        сохранить "ticket_description" = описание
    
    шаг контакты:
        спросить "📞 Укажите удобный способ связи (телефон/email):" → контакт
        если длина(контакт) < 5:
            ответ "❗ Укажите корректный контакт"
            повторить шаг
        сохранить "ticket_contact" = контакт
    
    шаг финал:
        # Генерируем ID тикета
        получить "ticket_count" → ticket_num
        запомни ticket_id = "TKT-{пользователь.id}-{ticket_num + 1}"
        
        # Сохраняем тикет
        получить "tickets" → tickets_list
        если тип(tickets_list) != "массив":
            запомни tickets_list = []
        
        запомни new_ticket = ["id", ticket_id, "status", "open", "priority", "ticket_priority"]
        запомни tickets_list = добавить(tickets_list, new_ticket)
        сохранить "tickets" = tickets_list
        сохранить "ticket_count" = ticket_num + 1
        
        ответ "✅ Тикет создан успешно!"
        ответ "🎫 Номер: {ticket_id}"
        ответ "📊 Категория: {ticket_priority}"
        ответ "⏱️ Среднее время ответа: 2-4 часа"
        
        # Уведомляем операторов
        лог "🚨 НОВЫЙ ТИКЕТ {ticket_id} от {пользователь.имя}"
        лог "Приоритет: {ticket_priority}"
        лог "Описание: {ticket_description}"
        
        кнопки:
            ["📋 Мои тикеты", "❓ FAQ"]
            ["🔙 Главное меню"]

# ──────────────────────────────────────────────────────────
# Сценарий FAQ
сценарий faq:
    шаг выбор:
        ответ "❓ Часто задаваемые вопросы:"
        ответ ""
        ответ "1. Как создать тикет?"
        ответ "2. Сколько ждать ответа?"
        ответ "3. Как получить бонус?"
        ответ "4. Как связаться с оператором?"
        ответ "5. Где посмотреть статус?"
        ответ ""
        
        спросить "Введите номер вопроса (1-5):" → номер
        если не число(номер):
            ответ "❗ Введите число от 1 до 5"
            повторить шаг
        
        если номер == 1:
            ответ "ℹ️ Нажмите '🎫 Новый тикет' или /new_ticket"
        если номер == 2:
            ответ "ℹ️ Обычно отвечаем в течение 2-4 часов"
            ответ "Критичные вопросы - в течение 30 минут"
        если номер == 3:
            ответ "ℹ️ Активно пользуйтесь поддержкой!"
            ответ "При 50 обращениях получите бонус 🎁"
        если номер == 4:
            ответ "ℹ️ Нажмите '👨‍💼 Оператор' для прямого чата"
            ответ "Работаем 24/7"
        если номер == 5:
            ответ "ℹ️ Нажмите '📋 Мои тикеты' для просмотра"
        
        если номер < 1 или номер > 5:
            ответ "❗ Неверный номер"
            повторить шаг
        
        кнопка "Ещё вопрос" -> "more_faq"
        кнопка "🔙 Главное меню" -> "main_menu"

при нажатии "more_faq":
    запустить faq

при нажатии "main_menu":
    старт

# ──────────────────────────────────────────────────────────
# Сценарий чата с оператором
сценарий чат_с_оператором:
    шаг начало:
        ответ "👨‍💼 Чат с оператором"
        ответ "Оператор подключится через 1-2 минуты"
        
        # Проверяем, не в чате ли уже
        получить "in_chat" → chatting
        если chatting == истина:
            ответ "⚠️ Вы уже в чате с оператором"
            вернуть
        
        сохранить "in_chat" = истина
        
        ответ "✅ Ожидайте подключения оператора..."
        кнопка "Отменить" -> "cancel_chat"

при нажатии "cancel_chat":
    сохранить "in_chat" = ложь
    ответ "❌ Чат отменён"
    старт

# ──────────────────────────────────────────────────────────
# Общие обработчики
иначе:
    # Если пользователь в чате - пересылаем оператору
    получить "in_chat" → in_chat
    если in_chat == истина:
        лог "[ЧАТ] {пользователь.имя}: {текст}"
        ответ "✅ Сообщение передано оператору"
    иначе:
        ответ "🤔 Не понял команду"
        ответ "Выберите из меню или используйте /help"
        кнопка "🎫 Новый тикет" -> "new_ticket"
        кнопка "❓ FAQ" -> "faq"
        кнопка "👨‍💼 Оператор" -> "operator"
