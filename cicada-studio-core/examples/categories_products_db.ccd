# Cicada3301
бот "TOKEN"

команды:
    "/start" - "Открыть меню"
    "/categories" - "Показать категории"

блок меню:
    ответ "Каталог из БД"
    inline-кнопки:
        ["📂 Категории" → "show_categories", "➕ Создать категорию" → "add_category"]

блок список_категорий:
    получить "категории" → категории
    если тип(категории) != "список":
        запомни категории = []

    если длина(категории) == 0:
        ответ "Категорий пока нет. Создайте первую."
        inline-кнопки:
            ["➕ Создать категорию" → "add_category"]
    иначе:
        ответ "Выберите категорию:"
        inline из бд "категории" callback "cat_" columns=2
        ответ "Управление каталогом:"
        inline-кнопки:
            ["➕ Создать категорию" → "add_category"]

блок товары_категории:
    ответ "Категория: {selected_category}"
    получить "товары_{selected_category}" → товары
    если тип(товары) != "список":
        запомни товары = []

    если длина(товары) == 0:
        ответ "В этой категории пока нет товаров."
    иначе:
        ответ "Товары в категории:"
        inline из бд "товары_{selected_category}" callback "product_" columns=2

    ответ "Действия:"
    inline-кнопки:
        ["➕ Создать товар" → "add_product", "🔙 К категориям" → "show_categories"]

старт:
    использовать меню

команда "/categories":
    использовать список_категорий

при нажатии "show_categories":
    использовать список_категорий

при нажатии "add_category":
    запустить создание_категории

при нажатии "add_product":
    получить "текущая_категория" → selected_category
    если не selected_category:
        ответ "Сначала выберите категорию."
        использовать список_категорий
        вернуть
    запустить создание_товара

при нажатии:
    если начинается_с(кнопка, "cat_"):
        запомни selected_category = срез(кнопка, 4)
        сохранить "текущая_категория" = selected_category
        использовать товары_категории
        вернуть

    если начинается_с(кнопка, "product_"):
        запомни selected_product = срез(кнопка, 8)
        ответ "Вы выбрали товар: {selected_product}"
        вернуть

сценарий создание_категории:
    шаг имя:
        спросить "Введите название категории:" → category_name

    шаг сохранить:
        получить "категории" → категории
        если тип(категории) != "список":
            запомни категории = []

        если содержит_элемент(категории, category_name):
            ответ "Такая категория уже есть: {category_name}"
        иначе:
            запомни категории = добавить(категории, category_name)
            сохранить "категории" = категории
            ответ "Категория создана: {category_name}"

        использовать список_категорий
        завершить сценарий

сценарий создание_товара:
    шаг имя:
        спросить "Введите название товара для категории {selected_category}:" → product_name

    шаг сохранить:
        получить "товары_{selected_category}" → товары
        если тип(товары) != "список":
            запомни товары = []

        если содержит_элемент(товары, product_name):
            ответ "Такой товар уже есть в категории {selected_category}: {product_name}"
        иначе:
            запомни товары = добавить(товары, product_name)
            сохранить "товары_{selected_category}" = товары
            ответ "Товар создан: {product_name}"

        использовать товары_категории
        завершить сценарий
